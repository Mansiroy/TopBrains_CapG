<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Book Bean -->
    <bean id="bookBean" class="com.cg.bean.Book">
    <property name="bookId" value="101"/>
    <property name="title" value="Spring Framework"/>
    <property name="author" value="Rod Johnson"/>
</bean>

<bean id="librarianBean" class="com.cg.bean.Librarian">
    <property name="librarianId" value="1"/>
    <property name="name" value="Amit"/>
    <property name="book" ref="bookBean"/>
</bean>

</beans>

