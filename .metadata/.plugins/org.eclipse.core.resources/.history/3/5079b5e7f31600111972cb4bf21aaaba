package com.cg.services;

import java.util.List;

import com.cg.bean.Employee;
import com.cg.dao.EmployeeDao;

public class EmployeeService implements IEmployeeService {

    private EmployeeDao dao = new EmployeeDao();

    @Override
    public boolean saveEmployee(Employee emp) {

        // Validation
        if (emp.getName() == null || emp.getName().length() < 3) {
            System.out.println("Invalid Name! Must be at least 3 characters.");
            return false;
        }

        if (emp.getEmail() == null || !emp.getEmail().contains("@")) {
            System.out.println("Invalid Email!");
            return false;
        }

        if (emp.getDob() == null) {
            System.out.println("DOB cannot be null!");
            return false;
        }

        return dao.saveEmployee(emp);
    }

    @Override
    public Employee findById(int eid) {

        if (eid <= 0) {
            System.out.println("Invalid ID!");
            return null;
        }

        return dao.findEmployee(eid);
    }

    @Override
    public List<Employee> getAllEmployees() {
        return dao.getAllEmployees();
    }

    @Override
    public boolean updateEmployeeName(int eid, String name) {

        if (name == null || name.length() < 3) {
            System.out.println("Invalid Name!");
            return false;
        }

        return dao.updateEmployeeName(eid, name);
    }

    @Override
    public boolean removeEmployee(int empid) {

        if (empid <= 0) {
            System.out.println("Invalid ID!");
            return false;
        }

        return dao.deleteEmployee(empid);
    }
}