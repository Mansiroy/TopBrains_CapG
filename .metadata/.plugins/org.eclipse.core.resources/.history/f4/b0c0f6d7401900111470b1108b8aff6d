	                    int uid = sc.nextInt();
	                    sc.nextLine();
	                    System.out.println("Enter New Name");
	                    String newName = sc.nextLine();

	                    service.updatePerson(uid,newName);
	                    break;

	                case 4:
	                    System.out.println("Enter Person ID");
	                    int did = sc.nextInt();
	                    service.deletePerson(did);
	                    break;

	                case 5:
	                    System.exit(0);
	            }
	        }
