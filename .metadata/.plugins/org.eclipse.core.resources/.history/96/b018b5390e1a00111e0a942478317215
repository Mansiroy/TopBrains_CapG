package TopBarinsAssignment2_07_03_2026;

import java.util.Arrays;
import java.util.List;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.hibernate.Transaction;
import org.hibernate.cfg.Configuration;

import jakarta.persistence.EntityManager;
import jakarta.persistence.EntityManagerFactory;
import jakarta.persistence.Persistence;

public class Main {

    @SuppressWarnings("deprecation")
	public static void main(String[] args) {
    	EntityManagerFactory emf = Persistence.createEntityManagerFactory("my-pu");
		EntityManager em =emf.createEntityManager();
		em.getTransaction().begin();

        Configuration cfg = new Configuration();
        cfg.configure("hibernate.cfg.xml");
        cfg.addAnnotatedClass(Author.class);
        cfg.addAnnotatedClass(Book.class);

        SessionFactory factory = cfg.buildSessionFactory();
        Session session = factory.openSession();
        Transaction tx = session.beginTransaction();

        // CREATE AUTHOR
        Author author = new Author();
        author.setBooks(null);

        // CREATE BOOKS
        Book b1 = new Book("Java Fundamentals",450,author);
        Book b2 = new Book("Advanced Java",650,author);
        Book b3 = new Book("Java Streams",550,author);

        List<Book> books = Arrays.asList(b1,b2,b3);

        author = new Author("James Gosling","james@gmail.com",books);

        session.save(author);

        tx.commit();
        session.close();

        System.out.println("Author and Books Inserted");



        // READ
        Session session2 = factory.openSession();

        List<Author> authors = session2.createQuery("from Author", Author.class).list();

        for(Author a : authors) {

            System.out.println("Author Id : "+a.getAuthorId());
            System.out.println("Author Name : "+a.getAuthorName());

            System.out.println("Books Written:");
            System.out.println("--------------------");

            for(Book b : a.getBooks()) {
                System.out.println(b.getTitle()+" - "+b.getPrice());
            }
        }

        session2.close();



        // UPDATE BOOK PRICE
        Session session3 = factory.openSession();
        Transaction tx3 = session3.beginTransaction();

        Book book = session3.createQuery(
                "from Book where title='Advanced Java'",Book.class)
                .uniqueResult();

        if(book!=null) {
            book.setPrice(700);
            session3.update(book);
        }

        tx3.commit();
        session3.close();

        System.out.println("Book price updated");



        // DELETE BOOK
        Session session4 = factory.openSession();
        Transaction tx4 = session4.beginTransaction();

        Book deleteBook = session4.createQuery(
                "from Book where title='Java Streams'",Book.class)
                .uniqueResult();

        if(deleteBook!=null) {
            session4.delete(deleteBook);
        }

        tx4.commit();
        session4.close();

        System.out.println("Book Deleted");



        // DELETE AUTHOR (Cascade Delete Books)
        Session session5 = factory.openSession();
        Transaction tx5 = session5.beginTransaction();

        Author deleteAuthor = session5.get(Author.class,1);

        if(deleteAuthor!=null) {
            session5.delete(deleteAuthor);
        }

        tx5.commit();
        session5.close();

        factory.close();

        System.out.println("Author and Books Deleted");
    }
}