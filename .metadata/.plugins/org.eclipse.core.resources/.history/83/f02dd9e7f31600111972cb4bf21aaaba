package com.cg.dao;

import java.util.List;
import org.hibernate.Session;
import org.hibernate.Transaction;
import com.cg.bean.Employee;
import com.cg.util.HibernateUtil;

public class EmployeeDao implements IEmployeeDao {

    @Override
    public boolean saveEmployee(Employee emp) {

        Transaction tx = null;

        try (Session session = HibernateUtil
                .getSessionFactory()
                .openSession()) {

            tx = session.beginTransaction();
            session.persist(emp);
            tx.commit();
            return true;

        } catch (Exception e) {
            if (tx != null) tx.rollback();
            e.printStackTrace();
            return false;
        }
    }

    @Override
    public Employee findEmployee(int id) {

        try (Session session = HibernateUtil
                .getSessionFactory()
                .openSession()) {

            return session.get(Employee.class, id);
        }
    }

    @Override
    public List<Employee> getAllEmployees() {

        try (Session session = HibernateUtil
                .getSessionFactory()
                .openSession()) {

            return session.createQuery("from Employee",
                    Employee.class).list();
        }
    }

    @Override
    public boolean updateEmployeeName(int id, String newName) {

        Transaction tx = null;

        try (Session session = HibernateUtil
                .getSessionFactory()
                .openSession()) {

            tx = session.beginTransaction();

            Employee emp = session.get(Employee.class, id);

            if (emp != null) {
                emp.setName(newName);
                tx.commit();
                return true;
            }

            return false;

        } catch (Exception e) {
            if (tx != null) tx.rollback();
            return false;
        }
    }

    @Override
    public boolean deleteEmployee(int id) {

        Transaction tx = null;

        try (Session session = HibernateUtil
                .getSessionFactory()
                .openSession()) {

            tx = session.beginTransaction();

            Employee emp = session.get(Employee.class, id);

            if (emp != null) {
                session.remove(emp);
                tx.commit();
                return true;
            }

            return false;

        } catch (Exception e) {
            if (tx != null) tx.rollback();
            return false;
        }
    }
}